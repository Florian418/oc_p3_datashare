POSTGRES_DB=datashare
POSTGRES_USER=datashare
POSTGRES_PASSWORD=change_me

GARAGE_ACCESS_KEY=change_me
GARAGE_SECRET_KEY=change_me
GARAGE_BUCKET=datashare-files
GARAGE_S3_ENDPOINT=http://localhost:3900

# secret HMAC (Base64) qui signe/vérifie les JWT — à générer par exemple avec :
# openssl rand -base64 32
JWT_SECRET=change_me

# clé API NVD (National Vulnerability Database), utilisée par le scan de sécurité OWASP
# Dependency-Check — à demander gratuitement sur https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=change_me
